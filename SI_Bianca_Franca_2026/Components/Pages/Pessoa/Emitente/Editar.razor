@page "/emitentes/editar/{Id:int}"
@rendermode InteractiveServer
@using SI_Bianca_Franca_2026.Services.Pessoa
@using SI_Bianca_Franca_2026.Services.Localizacao
@using SI_Bianca_Franca_2026.Models.Localizacao
@using SI_Bianca_Franca_2026.Models.Pessoa
@using SI_Bianca_Franca_2026.DTOs.Pessoa
@inject EmitentesService EmitentesService
@inject PaisesService PaisesService
@inject EstadosService EstadosService
@inject CidadesService CidadesService
@inject NavigationManager Nav

<div class="mb-3 d-flex align-items-center gap-2">
    <button class="btn btn-sm btn-outline-secondary" @onclick='() => Nav.NavigateTo("/emitentes")'>
        <i class="bi bi-arrow-left"></i>
    </button>
    <h3 class="mb-0">Editar Emitente</h3>
</div>

@if (carregando)
{
    <p>Carregando...</p>
}
else
{
    @if (!string.IsNullOrEmpty(mensagemErro))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensagemErro
        </div>
    }

    <EditForm Model="dto" OnValidSubmit="Salvar">
        <DataAnnotationsValidator />

        <div style="display: flex; flex-wrap: wrap; gap: 12px;">

            <div class="form-group" style="width: 80px;">
                <label>Código</label>
                <InputNumber class="form-control" @bind-Value="dto.Id" disabled />
            </div>

            <div class="form-group" style="width: 165px;">
                <label class="obrigatorio">Tipo</label>
                <InputSelect class="form-select" @bind-Value="dto.TipoPessoa">
                    <option value="FISICA">Pessoa Física</option>
                    <option value="JURIDICA">Pessoa Jurídica</option>
                </InputSelect>
                <ValidationMessage For="@(() => dto.TipoPessoa)" class="text-danger" />
            </div>

            <div class="form-group" style="width: 670px;">
                <label class="obrigatorio">Emitente</label>
                <InputText class="form-control" @bind-Value="dto.NomeRazaoSocial" maxlength="60" />
                <ValidationMessage For="@(() => dto.NomeRazaoSocial)" class="text-danger" />
            </div>

            <div class="form-group" style="width: 460px">
                <label>@(dto.TipoPessoa == "FISICA" ? "Apelido" : "Nome Fantasia")</label>
                <InputText class="form-control" @bind-Value="dto.ApelidoNomeFantasia" maxlength="40" />
            </div>

            <div class="form-group" style="width: 135px;">
                <label>CEP</label>
                <InputText class="form-control" @bind-Value="dto.Cep" maxlength="9" />
            </div>

            <div class="form-group" style="width: 565px;">
                <label>Logradouro</label>
                <InputText class="form-control" @bind-Value="dto.Logradouro" maxlength="50" />
            </div>

            <div class="form-group" style="width: 75px;">
                <label>Número</label>
                <InputText class="form-control" @bind-Value="dto.Numero" maxlength="5" />
            </div>

            <div class="form-group" style="width: 565px;">
                <label>Bairro</label>
                <InputText class="form-control" @bind-Value="dto.Bairro" maxlength="50" />
            </div>

            <div class="form-group" style="width: 565px;">
                <label>Complemento</label>
                <InputText class="form-control" @bind-Value="dto.Complemento" maxlength="50" />
            </div>

            <div class="form-group" style="width: 565px;">
                <label class="obrigatorio">País</label>
                <InputSelect class="form-select" @bind-Value="dto.IdPais"
                             @bind-Value:after="AoMudarPais">
                    <option value="0">Selecione...</option>
                    @foreach (var p in paises)
                    {
                        <option value="@p.Id.ToString()">@p.Pais</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => dto.IdPais)" class="text-danger" />
            </div>

            <div class="form-group" style="width: 545px;">
                <label>Estado</label>
                <InputSelect class="form-select" @bind-Value="idEstadoSelecionado"
                             @bind-Value:after="AoMudarEstado">
                    <option value="0">Selecione...</option>
                    @foreach (var e in estadosFiltrados)
                    {
                        <option value="@e.Id.ToString()">@e.Estado (@e.Uf)</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group" style="width: 545px;">
                <label>Cidade</label>
                <InputSelect class="form-select" @bind-Value="dto.IdCidade">
                    <option value="0">Selecione...</option>
                    @foreach (var c in cidadesFiltradas)
                    {
                        <option value="@c.Id.ToString()">@c.Cidade</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group" style="width: 135px;">
                <label>Celular</label>
                <InputText class="form-control" @bind-Value="dto.Telefone" maxlength="12" />
            </div>

            <div class="form-group" style="width: 565px;">
                <label>E-mail</label>
                <InputText class="form-control" @bind-Value="dto.Email" maxlength="50" />
                <ValidationMessage For="@(() => dto.Email)" class="text-danger" />
            </div>

            <div class="form-group" style="width: 150px;">
                <label class="@(EhBrasileiro ? "obrigatorio" : "")">
                    @(dto.TipoPessoa == "FISICA" ? "CPF" : "CNPJ")
                </label>
                <InputText class="form-control" @bind-Value="dto.CpfCnpj" maxlength="14" />
                <ValidationMessage For="@(() => dto.CpfCnpj)" class="text-danger" />
            </div>

            <div class="form-group" style="width: 150px;">
                <label>@(dto.TipoPessoa == "FISICA" ? "RG" : "Inscrição Estadual")</label>
                <InputText class="form-control" @bind-Value="dto.RgIe" maxlength="13" />
            </div>

            <div class="form-group">
                <label>Inscrição Municipal</label>
                <InputText class="form-control" @bind-Value="dto.InscricaoMunicipal" maxlength="20" />
            </div>

            <div class="form-group" style="width: 280px;">
                <label>Regime Tributário</label>
                <InputSelect class="form-control" @bind-Value="dto.RegimeTributario">
                    <option value="">Selecione...</option>
                    @foreach (var r in RegimesTributarios)
                    {
                        <option value="@r.Key">@r.Value</option>
                    }
                </InputSelect>
            </div>
        </div>
        <div class="card mb-3">
            <div class="card-header">Observações</div>
            <div class="card-body">
                <InputTextArea class="form-control" @bind-Value="dto.Observacao" rows="3" />
            </div>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
            <div class="form-group">
                <label>Data de Criação</label>
                <input class="form-control" disabled
                       value="@dto.DataCriacao.ToString("dd/MM/yyyy HH:mm:ss")" />
            </div>
            <div class="form-group">
                <label>Última Alteração</label>
                <input class="form-control" disabled
                       value="@dto.DataUltimaAlteracao.ToString("dd/MM/yyyy HH:mm:ss")" />
            </div>
            <div class="form-group">
                <label>Alterado por</label>
                <input class="form-control" disabled value="@dto.NomeUsuarioAlteracao" />
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mb-4">
            <button type="button" class="btn btn-secondary"
                    @onclick='() => Nav.NavigateTo("/emitentes")'>
                Cancelar
            </button>
            <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private EmitentesDTO dto = new();
    private string mensagemErro = string.Empty;
    private bool carregando = true;

    private List<Paises> paises = new();
    private List<Estados> estadosFiltrados = new();
    private List<Cidades> cidadesFiltradas = new();
    private int idEstadoSelecionado = 0;

    private bool EhBrasileiro => paises
        .FirstOrDefault(p => p.Id == dto.IdPais)?.Sigla == "BRA";

    protected override async Task OnInitializedAsync()
    {
        var todosPaises = await PaisesService.ListarTudo();
        paises = todosPaises.Where(p => p.Ativo).ToList();

        var emitente = await EmitentesService.Pesquisar(Id);
        if (emitente is null)
        {
            Nav.NavigateTo("/emitentes");
            return;
        }

        dto = new EmitentesDTO
        {
            Id = emitente.Id,
            TipoPessoa = emitente.TipoPessoa,
            NomeRazaoSocial = emitente.NomeRazaoSocial,
            CpfCnpj = emitente.CpfCnpj,
            RgIe = emitente.RgIe,
            ApelidoNomeFantasia = emitente.ApelidoNomeFantasia,
            IdPais = emitente.IdPais,
            IdCidade = emitente.IdCidade,
            Bairro = emitente.Bairro,
            Logradouro = emitente.Logradouro,
            Numero = emitente.Numero,
            Complemento = emitente.Complemento,
            Cep = emitente.Cep,
            Telefone = emitente.Telefone,
            Email = emitente.Email,
            InscricaoMunicipal = emitente.InscricaoMunicipal,
            RegimeTributario = emitente.RegimeTributario,
            Observacao = emitente.Observacao,
            Ativo = emitente.Ativo,
            DataCriacao = emitente.DataCriacao,
            DataUltimaAlteracao = emitente.DataUltimaAlteracao,
            NomeUsuarioAlteracao = emitente.NomeUsuarioAlteracao
        };

        if (emitente.IdPais > 0)
            estadosFiltrados = await EstadosService.ListarPorPais(emitente.IdPais);

        if (emitente.IdCidade.HasValue)
        {
            var cidade = await CidadesService.Pesquisar(emitente.IdCidade.Value);
            if (cidade != null)
            {
                idEstadoSelecionado = cidade.IdEstado;
                cidadesFiltradas = await CidadesService.ListarPorEstado(cidade.IdEstado);
            }
        }

        carregando = false;
    }

    private async Task AoMudarPais()
    {
        idEstadoSelecionado = 0;
        dto.IdCidade = null;
        cidadesFiltradas = new();

        if (dto.IdPais > 0)
            estadosFiltrados = await EstadosService.ListarPorPais(dto.IdPais);
        else
            estadosFiltrados = new();
    }

    private async Task AoMudarEstado()
    {
        dto.IdCidade = null;

        if (idEstadoSelecionado > 0)
            cidadesFiltradas = await CidadesService.ListarPorEstado(idEstadoSelecionado);
        else
            cidadesFiltradas = new();
    }

    private static Dictionary<string, string> RegimesTributarios => new()
    {
        { "SIMPLES_NACIONAL",         "Simples Nacional" },
        { "SIMPLES_NACIONAL_EXCESSO", "Simples Nacional — Excesso de sublimite" },
        { "LUCRO_PRESUMIDO",          "Lucro Presumido" },
        { "LUCRO_REAL",               "Lucro Real" },
        { "MEI",                      "MEI" }
    };

    private async Task Salvar()
    {
        try
        {
            mensagemErro = string.Empty;

            if (EhBrasileiro && string.IsNullOrWhiteSpace(dto.CpfCnpj))
            {
                mensagemErro = "CPF/CNPJ é obrigatório para emitentes do Brasil.";
                return;
            }

            await EmitentesService.Atualizar(MapearParaModel());
            Nav.NavigateTo("/emitentes");
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
        }
    }

    private Emitentes MapearParaModel() => new()
    {
        Id = dto.Id,
        TipoPessoa = dto.TipoPessoa,
        NomeRazaoSocial = dto.NomeRazaoSocial,
        CpfCnpj = dto.CpfCnpj != null
            ? new string(dto.CpfCnpj.Where(char.IsDigit).ToArray())
            : null,
        RgIe = dto.RgIe,
        ApelidoNomeFantasia = dto.ApelidoNomeFantasia,
        IdPais = dto.IdPais,
        IdCidade = dto.IdCidade == 0 ? null : dto.IdCidade,
        Bairro = dto.Bairro,
        Logradouro = dto.Logradouro,
        Numero = dto.Numero,
        Complemento = dto.Complemento,
        Cep = dto.Cep,
        Telefone = dto.Telefone,
        Email = dto.Email,
        InscricaoMunicipal = dto.InscricaoMunicipal,
        RegimeTributario = dto.RegimeTributario,
        Observacao = dto.Observacao,
        Ativo = dto.Ativo,
        DataCriacao = dto.DataCriacao
    };
}