@page "/fornecedores/novo"
@rendermode InteractiveServer
@using SI_Bianca_Franca_2026.Services.Pessoa
@using SI_Bianca_Franca_2026.Services.Localizacao
@using SI_Bianca_Franca_2026.Models.Localizacao
@using SI_Bianca_Franca_2026.Models.Pessoa
@using SI_Bianca_Franca_2026.DTOs.Pessoa
@inject FornecedoresService FornecedoresService
@inject PaisesService PaisesService
@inject EstadosService EstadosService
@inject CidadesService CidadesService
@inject NavigationManager Nav

<div class="mb-3 d-flex align-items-center gap-2">
    <button class="btn btn-sm btn-outline-secondary" @onclick='() => Nav.NavigateTo("/fornecedores")'>
        <i class="bi bi-arrow-left"></i>
    </button>
    <h3 class="mb-0">Novo Fornecedor</h3>
</div>

@if (!string.IsNullOrEmpty(mensagemErro))
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensagemErro
    </div>
}

<EditForm Model="dto" OnValidSubmit="Salvar">
    <DataAnnotationsValidator />

    <div class="card mb-3">
        <div class="card-header">Identificação</div>
        <div class="card-body">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group col-full">
                    <label class="obrigatorio">Tipo de Pessoa</label>
                    <InputSelect class="form-control" @bind-Value="dto.TipoPessoa">
                        <option value="FISICA">Pessoa Física</option>
                        <option value="JURIDICA">Pessoa Jurídica</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => dto.TipoPessoa)" class="text-danger" />
                </div>

                <div class="form-group col-full">
                    <label class="obrigatorio">@(dto.TipoPessoa == "FISICA" ? "Nome" : "Razão Social")</label>
                    <InputText class="form-control" @bind-Value="dto.NomeRazaoSocial" maxlength="150"
                               placeholder="@(dto.TipoPessoa == "FISICA" ? "Ex.: João da Silva" : "Ex.: Empresa LTDA")" />
                    <ValidationMessage For="@(() => dto.NomeRazaoSocial)" class="text-danger" />
                </div>

                <div class="form-group col-full">
                    <label>@(dto.TipoPessoa == "FISICA" ? "Apelido" : "Nome Fantasia")</label>
                    <InputText class="form-control" @bind-Value="dto.ApelidoNomeFantasia" maxlength="100" />
                </div>

                <div class="form-group col-full">
                    <label class="obrigatorio">Nacionalidade</label>
                    <InputSelect class="form-control" @bind-Value="dto.IdPais"
                                 @bind-Value:after="AoMudarPais">
                        <option value="0">Selecione...</option>
                        @foreach (var p in paises)
                        {
                            <option value="@p.Id.ToString()">@p.Pais</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => dto.IdPais)" class="text-danger" />
                </div>

                <div class="form-group">
                    <label class="@(EhBrasileiro ? "obrigatorio" : "")">
                        @(dto.TipoPessoa == "FISICA" ? "CPF" : "CNPJ")
                    </label>
                    <InputText class="form-control" @bind-Value="dto.CpfCnpj" maxlength="20"
                               placeholder="@(dto.TipoPessoa == "FISICA" ? "000.000.000-00" : "00.000.000/0000-00")" />
                    <ValidationMessage For="@(() => dto.CpfCnpj)" class="text-danger" />
                </div>

                <div class="form-group">
                    <label>@(dto.TipoPessoa == "FISICA" ? "RG" : "Inscrição Estadual")</label>
                    <InputText class="form-control" @bind-Value="dto.RgIe" maxlength="20" />
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Endereço</div>
        <div class="card-body">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group">
                    <label>Estado</label>
                    <InputSelect class="form-control" @bind-Value="idEstadoSelecionado"
                                 @bind-Value:after="AoMudarEstado">
                        <option value="0">Selecione...</option>
                        @foreach (var e in estadosFiltrados)
                        {
                            <option value="@e.Id.ToString()">@e.Estado (@e.Uf)</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Cidade</label>
                    <InputSelect class="form-control" @bind-Value="dto.IdCidade">
                        <option value="0">Selecione...</option>
                        @foreach (var c in cidadesFiltradas)
                        {
                            <option value="@c.Id.ToString()">@c.Cidade</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>CEP</label>
                    <InputText class="form-control" @bind-Value="dto.Cep" maxlength="9"
                               placeholder="Ex.: 85851-000" />
                </div>

                <div class="form-group col-full">
                    <label>Logradouro</label>
                    <InputText class="form-control" @bind-Value="dto.Logradouro" maxlength="150"
                               placeholder="Ex.: Rua das Flores" />
                </div>

                <div class="form-group">
                    <label>Número</label>
                    <InputText class="form-control" @bind-Value="dto.Numero" maxlength="10" />
                </div>

                <div class="form-group">
                    <label>Bairro</label>
                    <InputText class="form-control" @bind-Value="dto.Bairro" maxlength="80" />
                </div>

                <div class="form-group col-full">
                    <label>Complemento</label>
                    <InputText class="form-control" @bind-Value="dto.Complemento" maxlength="100" />
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Contato</div>
        <div class="card-body">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group">
                    <label>Telefone</label>
                    <InputText class="form-control" @bind-Value="dto.Telefone" maxlength="20"
                               placeholder="Ex.: (45) 99999-9999" />
                </div>

                <div class="form-group">
                    <label>E-mail</label>
                    <InputText class="form-control" @bind-Value="dto.Email" maxlength="254"
                               placeholder="Ex.: contato@email.com" />
                    <ValidationMessage For="@(() => dto.Email)" class="text-danger" />
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Observações</div>
        <div class="card-body">
            <InputTextArea class="form-control" @bind-Value="dto.Observacao" rows="3" />
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mb-4">
        <button type="button" class="btn btn-secondary"
                @onclick='() => Nav.NavigateTo("/fornecedores")'>
            Cancelar
        </button>
        <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
</EditForm>

@code {
    private FornecedoresDTO dto = new() { Ativo = true };
    private string mensagemErro = string.Empty;

    private List<Paises> paises = new();
    private List<Estados> estadosFiltrados = new();
    private List<Cidades> cidadesFiltradas = new();
    private int idEstadoSelecionado = 0;

    private bool EhBrasileiro => paises
        .FirstOrDefault(p => p.Id == dto.IdPais)?.Sigla == "BRA";

    protected override async Task OnInitializedAsync()
    {
        var todosPaises = await PaisesService.ListarTudo();
        paises = todosPaises.Where(p => p.Ativo).ToList();
    }

    private async Task AoMudarPais()
    {
        idEstadoSelecionado = 0;
        dto.IdCidade = null;
        cidadesFiltradas = new();

        if (dto.IdPais > 0)
            estadosFiltrados = await EstadosService.ListarPorPais(dto.IdPais);
        else
            estadosFiltrados = new();
    }

    private async Task AoMudarEstado()
    {
        dto.IdCidade = null;

        if (idEstadoSelecionado > 0)
            cidadesFiltradas = await CidadesService.ListarPorEstado(idEstadoSelecionado);
        else
            cidadesFiltradas = new();
    }

    private async Task Salvar()
    {
        try
        {
            mensagemErro = string.Empty;

            if (EhBrasileiro && string.IsNullOrWhiteSpace(dto.CpfCnpj))
            {
                mensagemErro = "CPF/CNPJ é obrigatório para fornecedores do Brasil.";
                return;
            }

            await FornecedoresService.Inserir(MapearParaModel());
            Nav.NavigateTo("/fornecedores");
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
        }
    }

    private Fornecedores MapearParaModel() => new()
    {
        TipoPessoa = dto.TipoPessoa,
        NomeRazaoSocial = dto.NomeRazaoSocial,
        CpfCnpj = dto.CpfCnpj != null
            ? new string(dto.CpfCnpj.Where(char.IsDigit).ToArray())
            : null,
        RgIe = dto.RgIe,
        ApelidoNomeFantasia = dto.ApelidoNomeFantasia,
        IdPais = dto.IdPais,
        IdCidade = dto.IdCidade == 0 ? null : dto.IdCidade,
        Bairro = dto.Bairro,
        Logradouro = dto.Logradouro,
        Numero = dto.Numero,
        Complemento = dto.Complemento,
        Cep = dto.Cep,
        Telefone = dto.Telefone,
        Email = dto.Email,
        Observacao = dto.Observacao,
        Ativo = dto.Ativo
    };
}