@page "/fornecedores"
@rendermode InteractiveServer
@using SI_Bianca_Franca_2026.Services.Pessoa
@using SI_Bianca_Franca_2026.Models.Pessoa
@inject FornecedoresService FornecedoresService
@inject NavigationManager Nav

<div class="mb-3">
    <h3 class="mb-0">Fornecedores</h3>
</div>

<div class="d-flex gap-2 mb-3">
    <input class="form-control" style="max-width: 300px;" placeholder="Pesquisar..."
           @bind="termoPesquisa" @bind:event="oninput" />
    <select class="w-auto" @bind="filtroStatus">
        <option value="ativo">Ativos</option>
        <option value="inativo">Inativos</option>
        <option value="todos">Todos</option>
    </select>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/fornecedores/novo")'>
        <i class="bi bi-plus-lg me-1"></i>Novo Fornecedor
    </button>
</div>

@if (fornecedores is null)
{
    <p>Carregando...</p>
}
else if (!FornecedoresFiltrados.Any())
{
    <p>Nenhum fornecedor encontrado.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tipo</th>
                <th>Nome / Razão Social</th>
                <th>CPF / CNPJ</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in FornecedoresFiltrados)
            {
                <tr>
                    <td>@f.Id</td>
                    <td>@(f.TipoPessoa == "FISICA" ? "Pessoa Física" : "Pessoa Jurídica")</td>
                    <td>@f.NomeRazaoSocial</td>
                    <td>@(f.CpfCnpj ?? "—")</td>
                    <td>
                        <span class="badge @(f.Ativo ? "bg-success" : "bg-danger")">
                            @(f.Ativo ? "Ativo" : "Inativo")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick='() => Nav.NavigateTo($"/fornecedores/editar/{f.Id}")'>
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Fornecedores>? fornecedores;
    private string filtroStatus = "ativo";
    private string termoPesquisa = string.Empty;

    private IEnumerable<Fornecedores> FornecedoresFiltrados =>
        (fornecedores ?? [])
        .Where(f => filtroStatus switch
        {
            "ativo" => f.Ativo,
            "inativo" => !f.Ativo,
            _ => true
        })
        .Where(f => string.IsNullOrWhiteSpace(termoPesquisa) ||
                    f.NomeRazaoSocial.Contains(termoPesquisa, StringComparison.OrdinalIgnoreCase) ||
                    (f.CpfCnpj != null && f.CpfCnpj.Contains(termoPesquisa, StringComparison.OrdinalIgnoreCase)) ||
                    (f.ApelidoNomeFantasia != null && f.ApelidoNomeFantasia.Contains(termoPesquisa, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        fornecedores = await FornecedoresService.ListarTudo();
    }
}