@using SI_Bianca_Franca_2026.DTOs.Produto
@using SI_Bianca_Franca_2026.Models.Produto
@using SI_Bianca_Franca_2026.Components.Shared

<Modal Visivel="Visivel" Titulo="@(Dto.Sku == string.Empty ? "Novo SKU" : "Editar SKU")" AoFechar="Fechar">

    @if (!string.IsNullOrEmpty(mensagemErro))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensagemErro
        </div>
    }

    <EditForm Model="Dto" OnValidSubmit="Salvar">
        <DataAnnotationsValidator />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">

            <div class="form-group col-full">
                <label class="obrigatorio">Código SKU</label>
                @if (EhEdicao)
                {
                    <input class="form-control" value="@Dto.Sku" disabled />
                }
                else
                {
                    <InputText class="form-control" @bind-Value="Dto.Sku" maxlength="50"
                               placeholder="Ex.: FEL-AZUL" />
                    <ValidationMessage For="@(() => Dto.Sku)" class="text-danger" />
                }
            </div>

            <div class="form-group">
                <label>GTIN / EAN</label>
                <InputText class="form-control" @bind-Value="Dto.GtinEan" maxlength="14"
                           placeholder="Código de barras" />
                <ValidationMessage For="@(() => Dto.GtinEan)" class="text-danger" />
            </div>

            <div class="form-group">
                <label>Status</label>
                <div class="form-check form-switch mt-1">
                    <InputCheckbox class="form-check-input" @bind-Value="Dto.Ativo" />
                    <label class="form-check-label">@(Dto.Ativo ? "Ativo" : "Inativo")</label>
                </div>
            </div>

            <div class="form-group">
                <label>Preço de Custo</label>
                <div class="input-group">
                    <span class="input-group-text">R$</span>
                    <input type="text" class="form-control"
                           value="@PrecoCustoTexto"
                           @onchange="e => PrecoCustoTexto = e.Value?.ToString() ?? string.Empty"
                           placeholder="0,00" />
                </div>
            </div>

            <div class="form-group">
                <label>Estoque Atual</label>
                <input type="text" class="form-control"
                       value="@EstoqueTexto"
                       @onchange="e => EstoqueTexto = e.Value?.ToString() ?? string.Empty"
                       placeholder="0" />
            </div>

            <div class="form-group">
                <label>Estoque Mínimo</label>
                <input type="text" class="form-control"
                       value="@EstoqueMinimoTexto"
                       @onchange="e => EstoqueMinimoTexto = e.Value?.ToString() ?? string.Empty"
                       placeholder="0" />
            </div>

        </div>

        <hr />

        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>Atributos</strong>
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    @onclick="AdicionarAtributo">
                <i class="bi bi-plus-lg me-1"></i>Adicionar
            </button>
        </div>

        @if (!Dto.Atributos.Any())
        {
            <p class="text-muted" style="font-size: 13px;">Nenhum atributo adicionado.</p>
        }

        @for (int i = 0; i < Dto.Atributos.Count; i++)
        {
            var idx = i;
            <div style="display: grid; grid-template-columns: 1fr 1fr 36px; gap: 8px; margin-bottom: 8px;">
                <div class="input-group">
                    <InputSelect class="form-control" @bind-Value="Dto.Atributos[idx].IdChave">
                        <option value="0">Selecione...</option>
                        @foreach (var chave in ChavesDisponiveis)
                        {
                            <option value="@chave.Id.ToString()">@chave.Chave</option>
                        }
                    </InputSelect>
                    <button type="button" class="btn btn-outline-secondary"
                            title="Nova chave"
                            @onclick="AbrirNovaChave">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>
                <div>
                    <InputText class="form-control" @bind-Value="Dto.Atributos[idx].Valor"
                               maxlength="150" placeholder="Ex.: Azul" />
                    <ValidationMessage For="@(() => Dto.Atributos[idx].Valor)" class="text-danger" />
                </div>
                <button type="button" class="btn btn-sm btn-outline-danger"
                        @onclick="() => RemoverAtributo(idx)">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        }

        <div class="form-actions mt-3">
            <button type="button" class="btn btn-secondary" @onclick="Fechar">Cancelar</button>
            <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
    </EditForm>
</Modal>

@* Modal de nova chave — fora do EditForm *@
<Modal Visivel="modalNovaChaveAberto"
       Titulo="Nova Chave de Atributo"
       AoFechar="() => modalNovaChaveAberto = false">
    @if (!string.IsNullOrEmpty(erroNovaChave))
    {
        <div class="alert alert-danger">@erroNovaChave</div>
    }
    <div class="form-group">
        <label class="obrigatorio">Chave</label>
        <input class="form-control" @bind="novaChaveTexto"
               placeholder="Ex.: Cor, Gramatura, Tamanho" maxlength="100" />
    </div>
    <div class="form-actions mt-3">
        <button type="button" class="btn btn-secondary"
                @onclick="() => modalNovaChaveAberto = false">
            Cancelar
        </button>
        <button type="button" class="btn btn-primary"
                @onclick="SalvarNovaChave">
            Salvar
        </button>
    </div>
</Modal>

@code {
    [Parameter, EditorRequired] public SkusDTO Dto { get; set; } = new();
    [Parameter, EditorRequired] public List<SkuAtributosChaves> ChavesDisponiveis { get; set; } = new();
    [Parameter] public bool Visivel { get; set; }
    [Parameter] public bool EhEdicao { get; set; }
    [Parameter] public EventCallback<SkusDTO> AoSalvar { get; set; }
    [Parameter] public EventCallback AoFechar { get; set; }
    [Parameter] public EventCallback<string> AoCriarChave { get; set; }

    private bool modalNovaChaveAberto = false;
    private string novaChaveTexto = string.Empty;
    private string erroNovaChave = string.Empty;
    private string mensagemErro = string.Empty;

    private string PrecoCustoTexto
    {
        get => Dto.PrecoCusto == null ? string.Empty : Dto.PrecoCusto.Value.ToString("N4");
        set
        {
            if (string.IsNullOrWhiteSpace(value)) Dto.PrecoCusto = null;
            else if (decimal.TryParse(value, System.Globalization.NumberStyles.Any,
                     System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var r))
                Dto.PrecoCusto = r;
        }
    }

    private string EstoqueTexto
    {
        get => Dto.Estoque == 0 ? string.Empty : Dto.Estoque.ToString("N4");
        set
        {
            if (string.IsNullOrWhiteSpace(value)) Dto.Estoque = 0;
            else if (decimal.TryParse(value, System.Globalization.NumberStyles.Any,
                     System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var r))
                Dto.Estoque = r;
        }
    }

    private string EstoqueMinimoTexto
    {
        get => Dto.EstoqueMinimo == 0 ? string.Empty : Dto.EstoqueMinimo.ToString("N4");
        set
        {
            if (string.IsNullOrWhiteSpace(value)) Dto.EstoqueMinimo = 0;
            else if (decimal.TryParse(value, System.Globalization.NumberStyles.Any,
                     System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var r))
                Dto.EstoqueMinimo = r;
        }
    }

    private void AdicionarAtributo() =>
        Dto.Atributos.Add(new SkusAtributosValoresDTO());

    private void RemoverAtributo(int idx) =>
        Dto.Atributos.RemoveAt(idx);

    private async Task Salvar()
    {
        mensagemErro = string.Empty;
        await AoSalvar.InvokeAsync(Dto);
    }

    private void AbrirNovaChave()
    {
        novaChaveTexto = string.Empty;
        erroNovaChave = string.Empty;
        modalNovaChaveAberto = true;
    }

    private async Task SalvarNovaChave()
    {
        if (string.IsNullOrWhiteSpace(novaChaveTexto))
        {
            erroNovaChave = "Campo obrigatório.";
            return;
        }
        await AoCriarChave.InvokeAsync(novaChaveTexto.Trim());
        modalNovaChaveAberto = false;
    }

    private async Task Fechar() => await AoFechar.InvokeAsync();
}