@using SI_Bianca_Franca_2026.DTOs.Produto
@using SI_Bianca_Franca_2026.Models.Produto
@using SI_Bianca_Franca_2026.Components.Shared

<Modal Visivel="Visivel" Titulo="@(Dto.Id == 0 ? "Adicionar Material" : "Editar Material")" AoFechar="Fechar">

    @if (!string.IsNullOrEmpty(mensagemErro))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensagemErro
        </div>
    }

    <EditForm Model="Dto" OnValidSubmit="Salvar">
        <DataAnnotationsValidator />

        <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">

            <div class="form-group">
                <label class="obrigatorio">Material (Matéria-Prima)</label>
                <input type="text" class="form-control mb-1" placeholder="Filtrar..."
                       @bind="termoBusca" @bind:event="oninput" />
                <InputSelect class="form-control" @bind-Value="Dto.IdProdutoMaterial">
                    <option value="0">Selecione...</option>
                    @foreach (var m in MateriaisFiltrados)
                    {
                        <option value="@m.Id.ToString()">
                            @m.Produto (@(m.OUnidadeMedida?.Sigla ?? "—"))
                        </option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Dto.IdProdutoMaterial)" class="text-danger" />
            </div>

            <div class="form-group">
                <label class="obrigatorio">Quantidade</label>
                <div class="input-group">
                    <input type="text" class="form-control"
                           value="@QuantidadeTexto"
                           @onchange="e => QuantidadeTexto = e.Value?.ToString() ?? string.Empty"
                           placeholder="0,0000" />
                    <span class="input-group-text">@UnidadeSelecionada</span>
                </div>
                <ValidationMessage For="@(() => Dto.Quantidade)" class="text-danger" />
            </div>

            <div class="form-group">
                <label>Observação</label>
                <InputTextArea class="form-control" @bind-Value="Dto.Observacao" rows="2" />
            </div>

        </div>

        <div class="form-actions mt-3">
            <button type="button" class="btn btn-secondary" @onclick="Fechar">Cancelar</button>
            <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
    </EditForm>
</Modal>

@code {
    [Parameter, EditorRequired] public FichasTecnicasDTO Dto { get; set; } = new();
    [Parameter, EditorRequired] public List<Produtos> MateriaisPrimas { get; set; } = new();
    [Parameter] public bool Visivel { get; set; }
    [Parameter] public EventCallback<FichasTecnicasDTO> AoSalvar { get; set; }
    [Parameter] public EventCallback AoFechar { get; set; }

    private string mensagemErro = string.Empty;
    private string termoBusca = string.Empty;

    private IEnumerable<Produtos> MateriaisFiltrados =>
        MateriaisPrimas.Where(m =>
            string.IsNullOrWhiteSpace(termoBusca) ||
            m.Produto.Contains(termoBusca, StringComparison.OrdinalIgnoreCase));

    private string UnidadeSelecionada =>
        MateriaisPrimas.FirstOrDefault(m => m.Id == Dto.IdProdutoMaterial)
            ?.OUnidadeMedida?.Sigla ?? "—";

    private string QuantidadeTexto
    {
        get => Dto.Quantidade == 0 ? string.Empty : Dto.Quantidade.ToString("N4");
        set
        {
            if (string.IsNullOrWhiteSpace(value)) Dto.Quantidade = 0;
            else if (decimal.TryParse(value, System.Globalization.NumberStyles.Any,
                     System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var r))
                Dto.Quantidade = r;
        }
    }

    private async Task Salvar()
    {
        mensagemErro = string.Empty;
        await AoSalvar.InvokeAsync(Dto);
    }

    private async Task Fechar() => await AoFechar.InvokeAsync();
}