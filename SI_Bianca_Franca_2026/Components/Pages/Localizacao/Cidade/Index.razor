@page "/cidades"
@rendermode InteractiveServer
@using SI_Bianca_Franca_2026.Models.Localizacao
@using SI_Bianca_Franca_2026.Components.Shared.Modais.Localizacao

<div class="mb-3">
    <h3 class="mb-0">Cidades</h3>
</div>

<div class="d-flex gap-2 mb-3">
    <input class="form-control" style="max-width: 300px;" placeholder="Pesquisar..."
           @bind="termoPesquisa" @bind:event="oninput" />

    <select class="w-auto" @bind="filtroStatus">
        <option value="ativo">Ativos</option>
        <option value="inativo">Inativos</option>
        <option value="todos">Todos</option>
    </select>

    <button class="btn btn-primary" @onclick="AbrirCadastro">
        <i class="bi bi-plus-lg me-1"></i>Nova Cidade
    </button>
</div>

@if (cidades is null)
{
    <p>Carregando...</p>
}
else if (!CidadesFiltradas.Any())
{
    <p>Nenhuma cidade encontrada.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Cidade</th>
                <th>Estado</th>
                <th>DDD</th>
                <th>Código IBGE</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cid in CidadesFiltradas)
            {
                <tr>
                    <td>@cid.Id</td>
                    <td>@cid.Cidade</td>
                    <td>@(cid.OEstado != null ? $"{cid.OEstado.Estado} ({cid.OEstado.Uf})" : "Não informado")</td>
                    <td>@cid.Ddd</td>
                    <td>@cid.CodigoIbge</td>
                    <td>
                        <span class="badge @(cid.Ativo ? "bg-success" : "bg-danger")">
                            @(cid.Ativo ? "Ativo" : "Inativo")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => AbrirEdicao(cid)">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<CidadesModal @ref="_modalCidade" AoSalvarComSucesso="OnCidadeSalva" />
