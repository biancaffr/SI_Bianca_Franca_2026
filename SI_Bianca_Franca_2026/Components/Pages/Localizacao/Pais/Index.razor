@page "/paises"
@rendermode InteractiveServer
@using SI_Bianca_Franca_2026.Models.Localizacao
@using SI_Bianca_Franca_2026.Components.Shared.Modais.Localizacao

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Países</h3>
</div>

<div class="d-flex gap-2 mb-3">
    <input class="form-control" style="max-width: 300px;" placeholder="Pesquisar..."
           @bind="termoPesquisa" @bind:event="oninput" />

    <select class="w-auto" @bind="filtroStatus">
        <option value="ativo">Ativos</option>
        <option value="inativo">Inativos</option>
        <option value="todos">Todos</option>
    </select>

    <button class="btn btn-primary" @onclick="AbrirCadastro">
        <i class="bi bi-plus-lg me-1"></i> Novo País
    </button>
</div>

@if (paises is null)
{
    <p>Carregando...</p>
}
else if (!PaisesFiltrados.Any())
{
    <p>Nenhum país encontrado.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>País</th>
                <th>Sigla</th>
                <th>DDI</th>
                <th>Moeda</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pais in PaisesFiltrados)
            {
                <tr>
                    <td>@pais.Id</td>
                    <td>@pais.Pais</td>
                    <td>@pais.Sigla</td>
                    <td>@pais.Ddi</td>
                    <td>@pais.Moeda</td>
                    <td>
                        <span class="badge @(pais.Ativo ? "bg-success" : "bg-danger")">
                            @(pais.Ativo ? "Ativo" : "Inativo")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => AbrirEdicao(pais)">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<PaisesModal @ref="_modalPais" AoSalvarComSucesso="OnPaisSalvo" />
