@page "/estados"
@rendermode InteractiveServer
@using SI_Bianca_Franca_2026.Models.Localizacao
@using SI_Bianca_Franca_2026.Components.Shared.Modais.Localizacao

<div class="mb-3">
    <h3 class="mb-0">Estados</h3>
</div>

<div class="d-flex gap-2 mb-3">
    <input class="form-control" style="max-width: 300px;" placeholder="Pesquisar..."
           @bind="termoPesquisa" @bind:event="oninput" />

    <select class="w-auto" @bind="filtroStatus">
        <option value="ativo">Ativos</option>
        <option value="inativo">Inativos</option>
        <option value="todos">Todos</option>
    </select>
    <button class="btn btn-primary" @onclick="AbrirCadastro">
        <i class="bi bi-plus-lg me-1"></i>Novo Estado
    </button>    
</div>

@if (estados is null)
{
    <p>Carregando...</p>
}
else if (!EstadosFiltrados.Any())
{
    <p>Nenhum estado encontrado.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Estado</th>
                <th>UF</th>
                <th>País</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var est in EstadosFiltrados)
            {
                <tr>
                    <td>@est.Id</td>
                    <td>@est.Estado</td>
                    <td>@est.Uf</td>
                    <td>@(est.OPais?.Pais ?? "Não informado")</td>
                    <td>
                        <span class="badge @(est.Ativo ? "bg-success" : "bg-danger")">
                            @(est.Ativo ? "Ativo" : "Inativo")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => AbrirEdicao(est)">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<EstadosModal @ref="_modalEstado" AoSalvarComSucesso="OnEstadoSalvo" />
