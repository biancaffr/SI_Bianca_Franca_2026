@using SI_Bianca_Franca_2026.DTOs.Pessoa
@using SI_Bianca_Franca_2026.Models.Pessoa
@using SI_Bianca_Franca_2026.Models.Localizacao
@using SI_Bianca_Franca_2026.Services.Pessoa
@using SI_Bianca_Franca_2026.Services.Localizacao
@using SI_Bianca_Franca_2026.Components.Shared
@using SI_Bianca_Franca_2026.Components.Shared.Modais.Localizacao
@inject ClientesService ClientesService
@inject PaisesService PaisesService
@inject EstadosService EstadosService
@inject CidadesService CidadesService

<Modal Visivel="_aberto"
       Titulo="@(_dto.Id == 0 ? "Novo Cliente" : "Editar Cliente")"
       Largura="960px"
       AoFechar="Fechar">

    @if (!string.IsNullOrEmpty(_erro))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @_erro
        </div>
    }

    @if (_carregando)
    {
        <p>Carregando...</p>
    }
    else
    {
        <EditForm Model="_dto" OnValidSubmit="Salvar">
            <DataAnnotationsValidator />

            <div style="display: flex; flex-wrap: wrap; gap: 12px;">

                @if (_dto.Id != 0)
                {
                    <div class="form-group" style="width: 80px;">
                        <label>Código</label>
                        <InputNumber class="form-control" @bind-Value="_dto.Id" disabled />
                    </div>
                }

                <div class="form-group" style="width: 165px;">
                    <label class="obrigatorio">Tipo</label>
                    <InputSelect class="form-select" @bind-Value="_dto.TipoPessoa">
                        <option value="FISICA">Pessoa Física</option>
                        <option value="JURIDICA">Pessoa Jurídica</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => _dto.TipoPessoa)" class="text-danger" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 280px;">
                    <label class="obrigatorio">@(_dto.Id != 0 ? "Cliente" : "Nome / Razão Social")</label>
                    <InputText class="form-control" @bind-Value="_dto.NomeRazaoSocial" maxlength="60" />
                    <ValidationMessage For="@(() => _dto.NomeRazaoSocial)" class="text-danger" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label>@(_dto.TipoPessoa == "FISICA" ? "Apelido" : "Nome Fantasia")</label>
                    <InputText class="form-control" @bind-Value="_dto.ApelidoNomeFantasia" maxlength="40" />
                </div>

                <div class="form-group" style="width: 100%;">
                    <hr class="my-1" />
                </div>

                <div class="form-group" style="width: 120px;">
                    <label>CEP</label>
                    <InputText class="form-control" @bind-Value="_dto.Cep" maxlength="9" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label>Logradouro</label>
                    <InputText class="form-control" @bind-Value="_dto.Logradouro" maxlength="50" />
                </div>

                <div class="form-group" style="width: 75px;">
                    <label>Número</label>
                    <InputText class="form-control" @bind-Value="_dto.Numero" maxlength="5" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label>Bairro</label>
                    <InputText class="form-control" @bind-Value="_dto.Bairro" maxlength="50" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label>Complemento</label>
                    <InputText class="form-control" @bind-Value="_dto.Complemento" maxlength="50" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label class="obrigatorio">País</label>
                    <div class="input-group">
                        <InputSelect class="form-select" @bind-Value="_dto.IdPais"
                                     @bind-Value:after="AoMudarPais">
                            <option value="0">Selecione...</option>
                            @foreach (var p in _paises)
                            {
                                <option value="@p.Id.ToString()">@p.Pais</option>
                            }
                        </InputSelect>
                        <button type="button" class="btn btn-outline-secondary"
                                title="Novo país" @onclick="() => _modalPais.Abrir()">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _dto.IdPais)" class="text-danger" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label>Estado</label>
                    <div class="input-group">
                        <InputSelect class="form-select" @bind-Value="_idEstadoSelecionado"
                                     @bind-Value:after="AoMudarEstado">
                            <option value="0">Selecione...</option>
                            @foreach (var e in _estadosFiltrados)
                            {
                                <option value="@e.Id.ToString()">@e.Estado (@e.Uf)</option>
                            }
                        </InputSelect>
                        <button type="button" class="btn btn-outline-secondary"
                                title="Novo estado"
                                @onclick="() => _modalEstado.Abrir(idPaisPreSelecionado: _dto.IdPais)">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label>Cidade</label>
                    <div class="input-group">
                        <InputSelect class="form-select" @bind-Value="_dto.IdCidade">
                            <option value="0">Selecione...</option>
                            @foreach (var c in _cidadesFiltradas)
                            {
                                <option value="@c.Id.ToString()">@c.Cidade</option>
                            }
                        </InputSelect>
                        <button type="button" class="btn btn-outline-secondary"
                                title="Nova cidade"
                                @onclick="() => _modalCidade.Abrir(idEstadoPreSelecionado: _idEstadoSelecionado)">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group" style="width: 100%;">
                    <hr class="my-1" />
                </div>

                <div class="form-group" style="width: 135px;">
                    <label>Celular</label>
                    <InputText class="form-control" @bind-Value="_dto.Telefone" maxlength="12" />
                </div>

                <div class="form-group" style="flex: 1; min-width: 220px;">
                    <label>E-mail</label>
                    <InputText class="form-control" @bind-Value="_dto.Email" maxlength="50" />
                    <ValidationMessage For="@(() => _dto.Email)" class="text-danger" />
                </div>

                <div class="form-group" style="width: 150px;">
                    <label class="@(EhBrasileiro ? "obrigatorio" : "")">
                        @(_dto.TipoPessoa == "FISICA" ? "CPF" : "CNPJ")
                    </label>
                    <InputText class="form-control" @bind-Value="_dto.CpfCnpj" maxlength="14" />
                    <ValidationMessage For="@(() => _dto.CpfCnpj)" class="text-danger" />
                </div>

                <div class="form-group" style="width: 150px;">
                    <label>@(_dto.TipoPessoa == "FISICA" ? "RG" : "Inscrição Estadual")</label>
                    <InputText class="form-control" @bind-Value="_dto.RgIe" maxlength="13" />
                </div>

                <div class="form-group" style="width: 145px;">
                    <label>Limite de Crédito</label>
                    <div class="input-group">
                        <span class="input-group-text">R$</span>
                        <input type="text" class="form-control"
                               value="@LimiteCreditoTexto"
                               @onchange="e => LimiteCreditoTexto = e.Value?.ToString() ?? string.Empty"
                               placeholder="0,00" maxlength="8" />
                    </div>
                    <ValidationMessage For="@(() => _dto.LimiteCredito)" class="text-danger" />
                </div>

                <div class="form-group" style="width: 100px;">
                    <label>Status</label>
                    <div class="form-check form-switch mt-1">
                        <InputCheckbox class="form-check-input" @bind-Value="_dto.Ativo" />
                        <label class="form-check-label">@(_dto.Ativo ? "Ativo" : "Inativo")</label>
                    </div>
                </div>

            </div>

            <div class="card mb-3 mt-2">
                <div class="card-header">Observações</div>
                <div class="card-body">
                    <InputTextArea class="form-control" @bind-Value="_dto.Observacao" rows="2" />
                </div>
            </div>

            @if (_dto.Id != 0)
            {
                <hr />
                <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 12px;">
                    <div class="form-group">
                        <label>Data de Criação</label>
                        <input class="form-control" disabled
                               value="@_dto.DataCriacao.ToString("dd/MM/yyyy HH:mm:ss")" />
                    </div>
                    <div class="form-group">
                        <label>Última Alteração</label>
                        <input class="form-control" disabled
                               value="@_dto.DataUltimaAlteracao.ToString("dd/MM/yyyy HH:mm:ss")" />
                    </div>
                    <div class="form-group">
                        <label>Alterado por</label>
                        <input class="form-control" disabled value="@_dto.NomeUsuarioAlteracao" />
                    </div>
                </div>
            }

            <div class="form-actions">
                <button type="button" class="btn btn-secondary" @onclick="Fechar">Cancelar</button>
                <button type="submit" class="btn btn-primary">Salvar</button>
            </div>

        </EditForm>
    }
</Modal>

<PaisesModal @ref="_modalPais" AoSalvarComSucesso="OnPaisSalvo" />
<EstadosModal @ref="_modalEstado" AoSalvarComSucesso="OnEstadoSalvo" />
<CidadesModal @ref="_modalCidade" AoSalvarComSucesso="OnCidadeSalva" />

@code {
    [Parameter] public EventCallback<Clientes> AoSalvarComSucesso { get; set; }

    private bool _aberto = false;
    private bool _carregando = false;
    private string _erro = string.Empty;
    private ClientesDTO _dto = new();

    private List<Paises> _paises = new();
    private List<Estados> _estadosFiltrados = new();
    private List<Cidades> _cidadesFiltradas = new();
    private int _idEstadoSelecionado = 0;

    private PaisesModal _modalPais = default!;
    private EstadosModal _modalEstado = default!;
    private CidadesModal _modalCidade = default!;

    private string LimiteCreditoTexto
    {
        get => _dto.LimiteCredito == 0 ? string.Empty : _dto.LimiteCredito.ToString("N2");
        set
        {
            if (string.IsNullOrWhiteSpace(value))
                _dto.LimiteCredito = 0;
            else if (decimal.TryParse(value, System.Globalization.NumberStyles.Any,
                     System.Globalization.CultureInfo.GetCultureInfo("pt-BR"), out var resultado))
                _dto.LimiteCredito = resultado;
        }
    }

    private bool EhBrasileiro => _paises
        .FirstOrDefault(p => p.Id == _dto.IdPais)?.Sigla == "BRA";

    /// <summary>Abre o modal para cadastro de novo cliente.</summary>
    public async Task AbrirNovo()
    {
        _erro = string.Empty;
        _dto = new ClientesDTO { Ativo = true };
        _idEstadoSelecionado = 0;
        _estadosFiltrados = new();
        _cidadesFiltradas = new();

        await CarregarPaises();
        _aberto = true;
        StateHasChanged();
    }

    /// <summary>Abre o modal para edição de um cliente existente pelo Id.</summary>
    public async Task AbrirEditar(int id)
    {
        _erro = string.Empty;
        _carregando = true;
        _aberto = true;
        StateHasChanged();

        await CarregarPaises();

        var cliente = await ClientesService.Pesquisar(id);
        if (cliente is null)
        {
            _aberto = false;
            StateHasChanged();
            return;
        }

        _dto = new ClientesDTO
        {
            Id = cliente.Id,
            TipoPessoa = cliente.TipoPessoa,
            NomeRazaoSocial = cliente.NomeRazaoSocial,
            CpfCnpj = cliente.CpfCnpj,
            RgIe = cliente.RgIe,
            ApelidoNomeFantasia = cliente.ApelidoNomeFantasia,
            IdPais = cliente.IdPais,
            IdCidade = cliente.IdCidade,
            Bairro = cliente.Bairro,
            Logradouro = cliente.Logradouro,
            Numero = cliente.Numero,
            Complemento = cliente.Complemento,
            Cep = cliente.Cep,
            Telefone = cliente.Telefone,
            Email = cliente.Email,
            LimiteCredito = cliente.LimiteCredito,
            Observacao = cliente.Observacao,
            Ativo = cliente.Ativo,
            DataCriacao = cliente.DataCriacao,
            DataUltimaAlteracao = cliente.DataUltimaAlteracao,
            NomeUsuarioAlteracao = cliente.NomeUsuarioAlteracao
        };

        if (_dto.IdPais > 0)
            _estadosFiltrados = await EstadosService.ListarPorPais(_dto.IdPais);

        if (cliente.IdCidade.HasValue)
        {
            var cidade = await CidadesService.Pesquisar(cliente.IdCidade.Value);
            if (cidade != null)
            {
                _idEstadoSelecionado = cidade.IdEstado;
                _cidadesFiltradas = await CidadesService.ListarPorEstado(_idEstadoSelecionado);
            }
        }

        _carregando = false;
        StateHasChanged();
    }

    private void Fechar()
    {
        _aberto = false;
        StateHasChanged();
    }

    private async Task CarregarPaises()
    {
        var todos = await PaisesService.ListarTudo();
        _paises = todos.Where(p => p.Ativo).ToList();
    }

    private async Task AoMudarPais()
    {
        _idEstadoSelecionado = 0;
        _dto.IdCidade = null;
        _cidadesFiltradas = new();

        if (_dto.IdPais > 0)
            _estadosFiltrados = await EstadosService.ListarPorPais(_dto.IdPais);
        else
            _estadosFiltrados = new();
    }

    private async Task AoMudarEstado()
    {
        _dto.IdCidade = null;

        if (_idEstadoSelecionado > 0)
            _cidadesFiltradas = await CidadesService.ListarPorEstado(_idEstadoSelecionado);
        else
            _cidadesFiltradas = new();
    }

    private async Task OnPaisSalvo(Paises pais)
    {
        await CarregarPaises();
        var novo = _paises.FirstOrDefault(p => p.Sigla == pais.Sigla);
        if (novo != null)
        {
            _dto.IdPais = novo.Id;
            await AoMudarPais();
        }
    }

    private async Task OnEstadoSalvo(Estados estado)
    {
        _estadosFiltrados = await EstadosService.ListarPorPais(_dto.IdPais);
        var novo = _estadosFiltrados.FirstOrDefault(e => e.Uf == estado.Uf);
        if (novo != null)
        {
            _idEstadoSelecionado = novo.Id;
            await AoMudarEstado();
        }
    }

    private async Task OnCidadeSalva(Cidades cidade)
    {
        _cidadesFiltradas = await CidadesService.ListarPorEstado(_idEstadoSelecionado);
        var nova = _cidadesFiltradas.FirstOrDefault(c => c.CodigoIbge == cidade.CodigoIbge);
        if (nova != null)
            _dto.IdCidade = nova.Id;
    }

    private async Task Salvar()
    {
        try
        {
            _erro = string.Empty;

            if (EhBrasileiro && string.IsNullOrWhiteSpace(_dto.CpfCnpj))
            {
                _erro = "CPF/CNPJ é obrigatório para clientes do Brasil.";
                return;
            }

            var cliente = MapearParaModel();

            if (cliente.Id == 0)
                await ClientesService.Inserir(cliente);
            else
                await ClientesService.Atualizar(cliente);

            await AoSalvarComSucesso.InvokeAsync(cliente);
            Fechar();
        }
        catch (Exception ex)
        {
            _erro = ex.Message;
        }
    }

    private Clientes MapearParaModel() => new()
    {
        Id = _dto.Id,
        TipoPessoa = _dto.TipoPessoa,
        NomeRazaoSocial = _dto.NomeRazaoSocial,
        CpfCnpj = _dto.CpfCnpj != null
            ? new string(_dto.CpfCnpj.Where(char.IsDigit).ToArray())
            : null,
        RgIe = _dto.RgIe,
        ApelidoNomeFantasia = _dto.ApelidoNomeFantasia,
        IdPais = _dto.IdPais,
        IdCidade = _dto.IdCidade == 0 ? null : _dto.IdCidade,
        Bairro = _dto.Bairro,
        Logradouro = _dto.Logradouro,
        Numero = _dto.Numero,
        Complemento = _dto.Complemento,
        Cep = _dto.Cep,
        Telefone = _dto.Telefone,
        Email = _dto.Email,
        LimiteCredito = _dto.LimiteCredito,
        Observacao = _dto.Observacao,
        Ativo = _dto.Ativo,
        DataCriacao = _dto.DataCriacao
    };
}
