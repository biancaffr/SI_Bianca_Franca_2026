@if (Visivel)
{
    <div class="modal-overlay" @onclick="Fechar">
        <div class="modal-container" style="width: @Largura; max-width: 96vw;" @onclick:stopPropagation>
            <div class="modal-header">
                <h5>@Titulo</h5>
                <button class="btn-fechar" @onclick="Fechar">&times;</button>
            </div>
            <div class="modal-body">
                @ChildContent
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visivel { get; set; }
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback AoFechar { get; set; }
    /// <summary>Largura do modal. Ex.: "450px", "900px", "80vw". Padrão: 450px.</summary>
    [Parameter] public string Largura { get; set; } = "450px";

    private async Task Fechar() => await AoFechar.InvokeAsync();
}